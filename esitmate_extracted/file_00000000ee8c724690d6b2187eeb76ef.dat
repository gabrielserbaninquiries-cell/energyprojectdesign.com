>>     if quote == '"':
>>         joined = joined.replace('"', '\\"')
>>     else:
>>         joined = joined.replace("'", "\\'")
>>
>>     new_line = prefix + quote + joined + quote
>>
>>     if found_closing:
>>         new_line += suffix
>>         new_lines = lines[:idx] + [new_line] + lines[j:]
>>     else:
>>         # Nu consumam linia de inchidere, doar inlocuim linia de start + fragmentele de continut.
>>         new_lines = lines[:idx] + [new_line] + lines[j:]
>>
>>     return new_lines, True, f"reparat linia {lineno}"
