>> print("normal login:", engine.authenticate("developer", "Amodilema_99").get("success"))
>> print("secret login:", engine.authenticate("developer", "**************/***************").get("success"))
>>
>> print("PATCH_POST_LOGIN_DEBUG_SECRET_OK")
