(.venv) PS C:\Users\40735\Desktop\Energy Project Design - Bransamente 2.0> @'
>> from pathlib import Path
>> import py_compile
>> import shutil
>> import time
>>
>> base = Path.cwd()
>> app_path = base / "app.py"
>> backup = base / f"app_backup_before_runtime_crash_logger_{time.strftime('%Y%m%d_%H%M%S')}.py"
>> shutil.copy2(app_path, backup)
>>
>> text = app_path.read_text(encoding="utf-8-sig", errors="replace")
>>
>> # Asigura importurile necesare
>> if "import traceback" not in text:
>>     text = text.replace("import os", "import os\nimport traceback", 1)
>>
>> if "from pathlib import Path" not in text:
>>     if "import traceback" in text:
>>         text = text.replace("import traceback", "import traceback\nfrom pathlib import Path", 1)
>>     else:
>>         text = text.replace("import os", "import os\nfrom pathlib import Path", 1)
>>
>> # Adauga metoda Tkinter exception handler in clasa principala daca nu exista
>> if "def report_callback_exception" not in text:
>>     marker = "    def show_page(self, page_name):"
>>     method = '''    def report_callback_exception(self, exc, val, tb):
>>         """
>>         Captureaza erorile aparute in callback-uri Tkinter/CustomTkinter.
>>         """
>>         try:
>>             Path("logs").mkdir(exist_ok=True)
>>             Path("logs/runtime_callback_error.log").write_text(
>>                 "".join(traceback.format_exception(exc, val, tb)),
>>                 encoding="utf-8"
>>             )
>>         except Exception:
>>             pass
>>
>>         try:
>>             from tkinter import messagebox
>>             messagebox.showerror(
>>                 "EPD - eroare runtime",
>>                 "A aparut o eroare in interfata aplicatiei.\\n\\nVezi logs/runtime_callback_error.log"
>>             )
>>         except Exception:
>>             pass
>>
>> '''
>>     if marker in text:
>>         text = text.replace(marker, method + marker, 1)
>>
>> app_path.write_text(text, encoding="utf-8")
>>
>> py_compile.compile(str(app_path), doraise=True)
>>
>> print("RUNTIME_CRASH_LOGGER_OK")
>> print(f"Backup app.py: {backup.name}")
>> '@ | Set-Content -Path ".\tools_add_runtime_crash_logger.py" -Encoding UTF8
