        f_PARAMETRI_TEHNICI = ctk.CTkFrame(main)
        f_PARAMETRI_TEHNICI.grid(row=8, column=0, padx=10, pady=10, sticky="nsew")
        ctk.CTkLabel(f_PARAMETRI_TEHNICI, text="PARAMETRI TEHNICI", font=("Arial",14,"bold")).grid(row=0,column=0,columnspan=3)

        self.entry(f_PARAMETRI_TEHNICI, "PARAMETRI TEHNICI Camp 1", 1, 0)
        self.entry(f_PARAMETRI_TEHNICI, "PARAMETRI TEHNICI Camp 2", 1, 1)
        self.entry(f_PARAMETRI_TEHNICI, "PARAMETRI TEHNICI Camp 3", 2, 0)
        self.combo(f_PARAMETRI_TEHNICI, "PARAMETRI TEHNICI Optiune", ["DA","NU"], 2, 1)
    
        f_EXECUTIE = ctk.CTkFrame(main)
        f_EXECUTIE.grid(row=9, column=0, padx=10, pady=10, sticky="nsew")
        ctk.CTkLabel(f_EXECUTIE, text="EXECUTIE", font=("Arial",14,"bold")).grid(row=0,column=0,columnspan=3)

        self.entry(f_EXECUTIE, "EXECUTIE Camp 1", 1, 0)
        self.entry(f_EXECUTIE, "EXECUTIE Camp 2", 1, 1)
        self.entry(f_EXECUTIE, "EXECUTIE Camp 3", 2, 0)
        self.combo(f_EXECUTIE, "EXECUTIE Optiune", ["DA","NU"], 2, 1)
    
        f_VERIFICARI = ctk.CTkFrame(main)
        f_VERIFICARI.grid(row=10, column=0, padx=10, pady=10, sticky="nsew")
        ctk.CTkLabel(f_VERIFICARI, text="VERIFICARI", font=("Arial",14,"bold")).grid(row=0,column=0,columnspan=3)

        self.entry(f_VERIFICARI, "VERIFICARI Camp 1", 1, 0)
        self.entry(f_VERIFICARI, "VERIFICARI Camp 2", 1, 1)
        self.entry(f_VERIFICARI, "VERIFICARI Camp 3", 2, 0)
        self.combo(f_VERIFICARI, "VERIFICARI Optiune", ["DA","NU"], 2, 1)
    
        f_OBSERVATII = ctk.CTkFrame(main)
        f_OBSERVATII.grid(row=11, column=0, padx=10, pady=10, sticky="nsew")
        ctk.CTkLabel(f_OBSERVATII, text="OBSERVATII", font=("Arial",14,"bold")).grid(row=0,column=0,columnspan=3)

        self.entry(f_OBSERVATII, "OBSERVATII Camp 1", 1, 0)
        self.entry(f_OBSERVATII, "OBSERVATII Camp 2", 1, 1)
        self.entry(f_OBSERVATII, "OBSERVATII Camp 3", 2, 0)
        self.combo(f_OBSERVATII, "OBSERVATII Optiune", ["DA","NU"], 2, 1)
    
    def page_consumatori(self):
        self.clear()
        frame = ctk.CTkFrame(self.content)
        frame.pack(fill="both", expand=True)

        self.consum_frame = ctk.CTkFrame(frame)
        self.consum_frame.pack(pady=20)

        ctk.CTkButton(frame, text="Adauga consumator", command=self.add_consumator).pack()

    def add_consumator(self):
        e = ctk.CTkEntry(self.consum_frame, placeholder_text="Consumator + debit")
        e.pack(pady=3)
        self.consumatori.append(e)

    def page_doc(self):
        self.clear()
        frame = ctk.CTkFrame(self.content)
        frame.pack(fill="both", expand=True)

        ctk.CTkButton(frame, text="Documentatie proiectare", command=self.doc).pack(pady=5)
        ctk.CTkButton(frame, text="Documentatie avizare", command=self.doc).pack(pady=5)
        ctk.CTkButton(frame, text="Genereaza PDF", command=self.pdf).pack(pady=5)
        ctk.CTkButton(frame, text="Salveaza", command=self.save).pack(pady=5)
        ctk.CTkButton(frame, text="Incarca", command=self.load).pack(pady=5)

    def save(self):
        data = {k:v.get() for k,v in self.vars.items()}
        data["consumatori"] = [c.get() for c in self.consumatori]
        with open("project.json","w") as f:
            json.dump(data,f)

    def load(self):
        path = filedialog.askopenfilename()
        if not path: return
        with open(path) as f:
            data = json.load(f)
        for k,v in data.items():
            if k in self.vars:
                self.vars[k].delete(0,"end")
                self.vars[k].insert(0,v)

    def doc(self):
        doc = Document()
        doc.add_heading("Proiect",0)
        for k,v in self.vars.items():
            doc.add_paragraph(f"{k}: {v.get()}")
        doc.save("proiect.docx")

    def pdf(self):
        pdf = FPDF()
        pdf.add_page()
        pdf.set_font("Arial",size=10)
        for k,v in self.vars.items():
            pdf.cell(200,10,txt=f"{k}: {v.get()}",ln=True)
        pdf.output("proiect.pdf")

if __name__ == "__main__":
    app = EnergyApp()
    app.mainloop()
