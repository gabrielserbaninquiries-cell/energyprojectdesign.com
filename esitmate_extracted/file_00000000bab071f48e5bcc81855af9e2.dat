        ctk.CTkLabel(f_PROTECTII, text="PROTECTII", font=("Arial",14,"bold")).grid(row=0,column=0,columnspan=3)

        self.entry(f_PROTECTII, "PROTECTII Camp 1", 1, 0)
        self.entry(f_PROTECTII, "PROTECTII Camp 2", 1, 1)
        self.entry(f_PROTECTII, "PROTECTII Camp 3", 2, 0)
        self.combo(f_PROTECTII, "PROTECTII Optiune", ["DA","NU"], 2, 1)
    
        f_DOCUMENTE = ctk.CTkFrame(main)
        f_DOCUMENTE.grid(row=6, column=0, padx=10, pady=10, sticky="nsew")
        ctk.CTkLabel(f_DOCUMENTE, text="DOCUMENTE", font=("Arial",14,"bold")).grid(row=0,column=0,columnspan=3)

        self.entry(f_DOCUMENTE, "DOCUMENTE Camp 1", 1, 0)
        self.entry(f_DOCUMENTE, "DOCUMENTE Camp 2", 1, 1)
