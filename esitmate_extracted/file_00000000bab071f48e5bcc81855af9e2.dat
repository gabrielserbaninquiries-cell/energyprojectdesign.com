
import customtkinter as ctk
from tkinter import messagebox, filedialog
from docx import Document
from fpdf import FPDF
import json, os

ctk.set_appearance_mode("dark")

class EnergyApp(ctk.CTk):
    def __init__(self):
        super().__init__()
        self.title("Energy Pro Enterprise")
        self.geometry("1800x1000")

        self.vars = {}
        self.consumatori = []

        self.init_ui()

    def init_ui(self):
        self.grid_columnconfigure(1, weight=1)

        self.sidebar = ctk.CTkFrame(self, width=260)
        self.sidebar.grid(row=0, column=0, sticky="ns")

        ctk.CTkLabel(self.sidebar, text="ENERGY PRO", font=("Arial",20,"bold")).pack(pady=20)

        ctk.CTkButton(self.sidebar, text="Modificare Proiect", command=self.page_proiect).pack(pady=6)
        ctk.CTkButton(self.sidebar, text="Consumatori", command=self.page_consumatori).pack(pady=6)
        ctk.CTkButton(self.sidebar, text="Documentatie", command=self.page_doc).pack(pady=6)

        self.content = ctk.CTkFrame(self)
        self.content.grid(row=0, column=1, sticky="nsew")

        self.page_proiect()

    def clear(self):
        for w in self.content.winfo_children():
            w.destroy()

    def entry(self, parent, name, r, c):
        e = ctk.CTkEntry(parent, placeholder_text=name)
        e.grid(row=r, column=c, padx=5, pady=5, sticky="ew")
        self.vars[name] = e
        return e

    def combo(self, parent, name, vals, r, c):
        cb = ctk.CTkComboBox(parent, values=vals)
        cb.grid(row=r, column=c, padx=5, pady=5, sticky="ew")
        self.vars[name] = cb
        return cb

    def page_proiect(self):
        self.clear()

        main = ctk.CTkScrollableFrame(self.content)
        main.pack(fill="both", expand=True)
        main.grid_columnconfigure((0,1,2), weight=1)

        # MULTIPLE PROFESSIONAL SECTIONS

        f_DATE_GENERALE = ctk.CTkFrame(main)
        f_DATE_GENERALE.grid(row=0, column=0, padx=10, pady=10, sticky="nsew")
        ctk.CTkLabel(f_DATE_GENERALE, text="DATE GENERALE", font=("Arial",14,"bold")).grid(row=0,column=0,columnspan=3)

        self.entry(f_DATE_GENERALE, "DATE GENERALE Camp 1", 1, 0)
        self.entry(f_DATE_GENERALE, "DATE GENERALE Camp 2", 1, 1)
        self.entry(f_DATE_GENERALE, "DATE GENERALE Camp 3", 2, 0)
        self.combo(f_DATE_GENERALE, "DATE GENERALE Optiune", ["DA","NU"], 2, 1)
    
        f_BRANSAMENT = ctk.CTkFrame(main)
        f_BRANSAMENT.grid(row=1, column=0, padx=10, pady=10, sticky="nsew")
        ctk.CTkLabel(f_BRANSAMENT, text="BRANSAMENT", font=("Arial",14,"bold")).grid(row=0,column=0,columnspan=3)

        self.entry(f_BRANSAMENT, "BRANSAMENT Camp 1", 1, 0)
        self.entry(f_BRANSAMENT, "BRANSAMENT Camp 2", 1, 1)
        self.entry(f_BRANSAMENT, "BRANSAMENT Camp 3", 2, 0)
        self.combo(f_BRANSAMENT, "BRANSAMENT Optiune", ["DA","NU"], 2, 1)
    
        f_VANE = ctk.CTkFrame(main)
        f_VANE.grid(row=2, column=0, padx=10, pady=10, sticky="nsew")
        ctk.CTkLabel(f_VANE, text="VANE", font=("Arial",14,"bold")).grid(row=0,column=0,columnspan=3)

        self.entry(f_VANE, "VANE Camp 1", 1, 0)
        self.entry(f_VANE, "VANE Camp 2", 1, 1)
        self.entry(f_VANE, "VANE Camp 3", 2, 0)
        self.combo(f_VANE, "VANE Optiune", ["DA","NU"], 2, 1)
    
        f_PRESIUNI = ctk.CTkFrame(main)
