import customtkinter as ctk
from tkinter import filedialog, messagebox

from pages.base import BasePage

from services.license_service import (
    set_active_role,
    license_status_text,
)
from services.verifier_service import (
    upsert_verifier,
    list_verifiers,
    attach_stamp_to_verifier,
    create_authorization_word,
    register_authorization,
)
from services.project_validator_service import (
    validate_vgd_authorization,
    validate_rte_authorization,
    format_validation_report,
)


class VerifiersPage(BasePage):
    def __init__(self, parent, app):
        super().__init__(parent, app)
        self.pack(fill="both", expand=True)

        self.title("Verificatori - VGD / RTE")

        self.selected_verifier_id = None

        main = ctk.CTkScrollableFrame(self, fg_color="transparent")
        main.pack(fill="both", expand=True, padx=24, pady=18)
        main.grid_columnconfigure(0, weight=1)
        main.grid_columnconfigure(1, weight=1)

        self.profile_card = self.card(main, 0, 0)
        self.action_card = self.card(main, 0, 1)
        self.registry_card = self.card(main, 1, 0)
        self.registry_card.grid(columnspan=2, sticky="nsew")

        self.build_profile_card()
        self.build_action_card()
        self.build_registry_card()

        self.refresh_registry()

    def build_profile_card(self):
        self.section_title(self.profile_card, "Profil verificator", 0, 0, 2)

        self.role = self.combo(self.profile_card, "Rol verificator", ["VGD", "RTE"], 1, 0)
        self.name = self.field(self.profile_card, "Nume verificator", 2, 0)
        self.authorization_number = self.field(self.profile_card, "Numar atestat / autorizatie", 3, 0)
        self.company = self.field(self.profile_card, "Societate verificator", 4, 0)
        self.email = self.field(self.profile_card, "Email verificator", 5, 0)
        self.phone = self.field(self.profile_card, "Telefon verificator", 6, 0)
        self.expiry = self.field(self.profile_card, "Data expirare atestat", 7, 0)

        self.primary_button(
            self.profile_card,
            "Salveaza / activeaza verificator",
            command=self.save_verifier,
            row=8,
            column=0,
            columnspan=2
        )

        self.secondary_button(
            self.profile_card,
            "Incarca stampila verificator",
            command=self.upload_stamp,
            row=9,
            column=0,
            columnspan=2
        )

        self.violet_button(
            self.profile_card,
            "Activeaza licenta demo pentru rol",
