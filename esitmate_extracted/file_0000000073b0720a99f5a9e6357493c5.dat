import os
import customtkinter as ctk
from PIL import Image
from tkinter import messagebox, filedialog

from core.app_state import AppState

from pages.user import UserPage
from pages.project import ProjectPage
from pages.documentation import DocumentationPage
from pages.stamps import StampsPage
from pages.emails import EmailsPage
from pages.assistant_user import AssistantUserPage
from pages.assistant_ai import AssistantAIPage
from pages.products import ProductsPage
from pages.contact import ContactPage
from pages.verifiers import VerifiersPage

from services.command_registry import find_command, ensure_registry
from services.document_service import (
    bulk_generate_word_documents,
    create_zip_from_generated,
    create_generation_report,
)
from services.project_service import register_project_snapshot
from services.validation_service import validate_project
from services.project_io_service import (
    save_epd_project,
    load_epd_project,
    apply_epd_to_state,
)


ctk.set_appearance_mode("light")
ctk.set_default_color_theme("green")


APP_NAME = "Energy Project Design - Bransamente 2.0"

FONT_MAIN = "Segoe UI"

COLOR_BG = "#F5FAF8"
COLOR_PANEL = "#FFFFFF"
COLOR_PANEL_SOFT = "#F8FCFB"
COLOR_SIDEBAR = "#FFFFFF"

COLOR_TEXT = "#0D1B2A"
COLOR_MUTED = "#64748B"
COLOR_BORDER = "#DDE7E3"

COLOR_GREEN = "#008E5A"
COLOR_GREEN_LIGHT = "#E1F6EE"
COLOR_GREEN_DARK = "#006D47"

COLOR_VIOLET = "#7B61FF"
COLOR_VIOLET_SOFT = "#F0ECFF"


class EnergyProjectDesign(ctk.CTk):
    def __init__(self):
        super().__init__()

        self.title(APP_NAME)
        self.geometry("1760x980")
        self.minsize(1320, 780)

        ensure_registry()

        self.app_state = AppState()

        self.configure(fg_color=COLOR_BG)

        self.grid_columnconfigure(0, weight=0)
        self.grid_columnconfigure(1, weight=1)
        self.grid_rowconfigure(0, weight=1)
        self.grid_rowconfigure(1, weight=0)

        self.nav_buttons = {}

        self.build_sidebar()
        self.build_main_area()
        self.build_bottom_status()

        self.show_page("Acasa")

    # ======================================================
    # SIDEBAR
    # ======================================================

    def build_sidebar(self):
        self.sidebar = ctk.CTkFrame(
            self,
            width=292,
            corner_radius=0,
            fg_color=COLOR_SIDEBAR
        )
        self.sidebar.grid(row=0, column=0, rowspan=2, sticky="ns")
        self.sidebar.grid_propagate(False)

        brand = ctk.CTkFrame(self.sidebar, fg_color="transparent")
        brand.pack(fill="x", padx=22, pady=(22, 14))

        logo_path = self.get_logo_path()

        if logo_path:
            try:
                logo = ctk.CTkImage(
                    light_image=Image.open(logo_path),
                    dark_image=Image.open(logo_path),
                    size=(54, 54)
                )
                ctk.CTkLabel(
                    brand,
                    image=logo,
                    text=""
                ).grid(row=0, column=0, rowspan=2, padx=(0, 12), sticky="w")
            except Exception:
                self.fallback_logo(brand)
        else:
            self.fallback_logo(brand)

        ctk.CTkLabel(
            brand,
            text="ENERGY PROJECT DESIGN",
            font=(FONT_MAIN, 18, "bold"),
            text_color=COLOR_TEXT
        ).grid(row=0, column=1, sticky="w")

        ctk.CTkLabel(
            brand,
            text="Bransamente gaze naturale 2.0",
            font=(FONT_MAIN, 12),
            text_color=COLOR_MUTED
        ).grid(row=1, column=1, sticky="w", pady=(1, 0))

        nav = ctk.CTkFrame(self.sidebar, fg_color="transparent")
        nav.pack(fill="both", expand=True, padx=16, pady=(6, 4))

        nav_items = [
            ("Acasa", "Acasa"),
            ("User", "User"),
            ("Date Proiect", "Proiect"),
            ("Date Tehnice", "Proiect"),
            ("Documentatie", "Documentatie"),
            ("Carti Tehnice", "CartiTehnice"),
            ("Verificatori VGD/RTE", "Verificatori"),
            ("Stampile", "Stampile"),
            ("Email-uri", "Emailuri"),
            ("Assistant User", "AssistantUser"),
            ("Assistant AI Developer", "AssistantAI"),
            ("Produse & Licente", "Produse"),
            ("Colaborari", "Colaborari"),
            ("Contact & Sugestii", "Contact"),
        ]

        for text, page in nav_items:
            btn = ctk.CTkButton(
                nav,
                text=text,
                height=41,
                corner_radius=15,
                anchor="w",
                fg_color="transparent",
                hover_color=COLOR_GREEN_LIGHT,
                text_color=COLOR_TEXT,
                font=(FONT_MAIN, 12, "bold"),
                command=lambda p=page: self.show_page(p)
            )
            btn.pack(fill="x", pady=2)
            self.nav_buttons[page] = btn

        support = ctk.CTkFrame(
            self.sidebar,
            fg_color=COLOR_PANEL_SOFT,
            corner_radius=18,
            border_width=1,
            border_color=COLOR_BORDER
        )
        support.pack(fill="x", padx=18, pady=(8, 12))

        ctk.CTkLabel(
            support,
            text="Asistenta rapida",
            font=(FONT_MAIN, 12, "bold"),
            text_color=COLOR_TEXT
        ).pack(anchor="w", padx=15, pady=(12, 0))

        ctk.CTkButton(
            support,
            text="Deschide suport",
            height=30,
            fg_color="transparent",
            hover_color=COLOR_GREEN_LIGHT,
            text_color=COLOR_GREEN_DARK,
            font=(FONT_MAIN, 11, "bold"),
            command=lambda: self.show_page("Contact")
        ).pack(anchor="w", padx=9, pady=(4, 10))

        license_card = ctk.CTkFrame(
            self.sidebar,
            fg_color=COLOR_GREEN_LIGHT,
            corner_radius=18,
            border_width=1,
            border_color="#BCEBDD"
        )
        license_card.pack(fill="x", padx=18, pady=(0, 18))

        ctk.CTkLabel(
            license_card,
            text="Licenta activa",
            font=(FONT_MAIN, 13, "bold"),
            text_color=COLOR_GREEN_DARK
        ).pack(anchor="w", padx=15, pady=(12, 0))

        ctk.CTkLabel(
            license_card,
            text="Professional / Verifier Core\nUpdate + EPD Project ready",
            font=(FONT_MAIN, 11),
            text_color=COLOR_TEXT
        ).pack(anchor="w", padx=15, pady=(3, 12))
